# polyforge environment for this workspace.
# Copy to .env.dev and edit values. Never commit .env.dev.

AUTHOR=wxk

# 容器镜像仓库（如果你的工作流涉及镜像 push）
# 如果你推到自己的私有仓库，在这里覆盖
# REGISTRY=your-registry.example.com/your-project

# /polyforge:review / /dev-ieops review 用哪个外部工具做 staff-engineer / challenge review
# 可选：codex（需装 OpenAI Codex CLI）| opencode
# 未设时 skill 会按 codex > opencode 顺序自动检测 $PATH
# REVIEW_TOOL=codex

# /polyforge:up / /polyforge:commit 用哪个 ticket 系统搜/建 ticket
# 可选：jira（默认，需 Atlassian MCP）| github（需 gh CLI 已登录）
# 已有 ID 的情况（如 IEBE-1543 / #42 / gh-42）按 ID 格式自动识别，不受此配置影响
TICKET_SYSTEM=github
